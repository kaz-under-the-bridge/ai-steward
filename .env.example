# Slack App
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# 許可チャンネル（カンマ区切り）
ALLOWED_CHANNEL_IDS=C0XXXXXXX

# Claude Code
CLAUDE_HOME=/home/kaz
CLAUDE_CWD=/home/kaz/git

# チャンネル→リポ バインディング（channelId:repoAbsPath, カンマ区切り）
# CHANNEL_REPO_BINDINGS=C0XXXXXXX:/home/kaz/git/.../repo-name

# リポ別CLI設定は config/repos.json で管理
# permissionMode, addDirs, extraArgs をリポ名単位で指定可能

# ログ
LOG_LEVEL=info
